# ── LLM (HuggingFace router for vision models) ────────────────────────────────
HF_TOKEN=your_huggingface_token_here

# ── Upstash Redis (job state)  ─────────────────────────────────────────────────
# Free tier at upstash.com → Create Database → copy REST URL + token
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_token_here

# ── Vercel Blob (video storage)  ───────────────────────────────────────────────
# Vercel dashboard → Storage → Blob → Create store → copy token
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_your_token_here
